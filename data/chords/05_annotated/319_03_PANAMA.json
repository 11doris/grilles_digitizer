    "sections": {
      "intro": "V (Eb) into a dim chord, then V/V-bVI7-vi with a Db7 neighbor, ending on V in first inversion",
      "s1_A": "Alternation of V (Eb) and V/V (Bb7) resolving repeatedly to V",
      "s1_A1": "V/V-V pattern, then IV-#ivdim, I6/4-V/ii(C7), V/ii(F7)-V/V(Bb7) cadencing to V",
      "s2_A": "I-#idim-V, then dominant cycle C7-F7-Bb7 (V/vi-V/ii-V/V) into V and V7 (Eb7)",
      "s2_A1": "Same I-#idim-V with dominant cycle, ending on V region (Eb)",
      "s3_A": "I-Iaug-IV-IV-V7-V7-I trio strain firmly in tonic",
      "s3_A1": "I with chromatic aug line (Ab-Ab#5-Ab6-Ab7=V/IV), then iii-V/iii (Cm-G7) closing on V7",
      "s4_A": "I sustained then dominant V7 (Eb7) back to I",
      "s4_B": "I-V/IV(Ab7)-IV-#ivdim-I-V7-I plagal-flavored strain",
      "s5_A": "I-V(Eb)-V/V(Bb7)-V pattern",
      "s5_A1": "Repeat of I-V-V/V-V pattern",
      "coda": "I-V7 alternation resolving to I"
    },
    "modulates": false
  },
