    "sections": {
      "A": "Starts on I (Emaj7) then tonicizes descending major-third centers: bVII (Eb) in bar 4, bVI (Db) in bar 5, and V-area (C) in bar 8, each approached by its own ii-V, ending with a ii-V (F#m7-B7) back to I",
      "A1": "Same as A: I with major-third-cycle tonicizations to Ebmaj7, Dbmaj7 and Cmaj7",
      "B": "ii-V to Bb (Cm7b5-F7), ii-V to I (F#m7b5-B7) landing on Emaj9, then ii-V to Eb (Fm7-Bb7)",
      "A2": "Restatement of A ending on Cmaj7",
      "interlude": "Altered dominant C9#5 held, then Gbmaj9, Fm(maj7) and C7b5 as a coloristic tag"
    },
    "modulates": false
  },
